# ---------------------------------------------------------------------------
# City Pharma Agent — PRODUCTION environment (template)
#
# You do not normally write this file by hand. `deploy/aws/install.sh` generates
# it, filling every GENERATED value below with `openssl rand` output and every
# DERIVED value from the domain you pass on the command line. This template
# exists to document what ends up in there and to make a hand-built deploy
# possible.
#
# The real file is .env.prod, mode 0600, and it is the only place the admin
# password, the Postgres password and the OpenRouter key exist. It is NOT in git
# (make sure .gitignore covers it). Back it up somewhere you can survive losing
# the box.
# ---------------------------------------------------------------------------

# ===== YOU MUST SUPPLY THIS ================================================
# The only value the installer cannot invent. Get one at
# https://openrouter.ai/keys. The installer refuses to run without it.
OPENROUTER_API_KEY=sk-or-xxxxx

# ===== DERIVED FROM THE DOMAIN YOU INSTALL WITH ============================
# install.sh sets all of these from `install.sh pharma.yourco.com admin@yourco.com`.
PHARMA_DOMAIN=pharma.yourco.com
ACME_EMAIL=admin@yourco.com

# CORS. NOT "*" — a wildcard lets any site on the internet drive the embed API
# from a visitor's browser. Add each customer site that embeds the widget here,
# comma-separated, and REBUILD/RESTART the api after editing.
ALLOWED_ORIGINS=https://pharma.yourco.com

# Marks the SSO state cookie Secure. We are behind TLS now, so: true.
COOKIE_SECURE=true

# Base URL the embed snippet points at (what you paste into a customer's site).
EMBED_PUBLIC_BASE=https://pharma.yourco.com

# ===== GENERATED BY install.sh (openssl rand) ==============================
# Never ship a default here. Every one of these is a full compromise if guessed.

# HMAC + session-token signing, 32 bytes hex.
# MUST equal the Laravel side's CITYAGENT_SECRET_KEY if you sign embed users.
SECRET_KEY=

# Seed super-admin. Created on first boot; there is no public signup.
# This is the break-glass account — it still works when Keycloak/LDAP is down.
ADMIN_EMAIL=admin@pharma.yourco.com
ADMIN_PASSWORD=

# Legacy /admin gate, superseded by the JWT user auth. Generated anyway so it is
# never the empty-string default.
ADMIN_TOKEN=

# Postgres. Used by the postgres container AND interpolated into POSTGRES_URL by
# docker-compose.prod.yml. Changing it after the first boot does NOT change the
# password of the already-initialised database — initdb only reads it once.
POSTGRES_PASSWORD=

# ===== EMBED CREDENTIALS ===================================================
# false in prod. When true, the app seeds a `web`/`web` credential if the store
# is empty — convenient in dev, an open door in prod. With it false, NOTHING is
# seeded, so install.sh mints a real credential over the admin API after boot
# and prints it. If you wipe the redis volume you lose that credential and every
# embedded widget stops authenticating (fail-closed): re-mint via
# POST /admin/credentials.
EMBED_DEV_CREDENTIAL=false

# ===== SFTP (the partner drop point) =======================================
# Prod is KEY-AUTH ONLY: docker-compose.prod.yml creates the user with an empty
# password field, which disables password login. SFTP_PASSWORD is therefore
# deliberately EMPTY here — the admin UI reads it and will correctly report that
# there is no password to hand out, rather than advertising one that cannot work.
SFTP_PASSWORD=

# What a PARTNER dials. The api container cannot discover its own public address,
# so this is operator knowledge. install.sh sets the host from your domain.
SFTP_PUBLIC_HOST=pharma.yourco.com
SFTP_PUBLIC_PORT=2222
# Changing the username also means changing the /home/pharma/upload volume mount
# in docker-compose.yml. Leave it unless you are prepared to do both.
SFTP_USERNAME=pharma

# Where the api writes partner public keys. This is the container path of the
# shared `sftp_ssh` volume, which the sftp container sees as ~/.ssh. Do not
# change it without changing both compose files.
SFTP_KEYS_DIR=/sftp_ssh

# ===== TUNABLES (safe defaults; edit if you know why) ======================
OPENROUTER_MODEL=google/gemini-3.5-flash
EMBEDDING_MODEL=google/gemini-embedding-2
CACHE_TTL_SECONDS=600
RATE_LIMIT_PER_MIN=30
SESSION_TTL_SECONDS=900
# How long an issued login token stays valid.
AUTH_TOKEN_TTL_HOURS=12
LOG_LEVEL=INFO
CHAT_LOG_RETENTION_DAYS=30

# Ingest worker: where it reads dropped files and how often it scans. The dirs
# are container paths on the sftp_data volume — change only alongside compose.
DATA_DIR=data
INCOMING_DIR=/incoming
WATCH_INTERVAL_SECONDS=15
# Embed new/changed catalog rows in the background so an upload returns fast.
EMBED_IN_BACKGROUND=true

# Multi-turn chat memory. Adds prompt tokens, no extra LLM call.
HISTORY_ENABLED=true
HISTORY_TURNS=3

# ---- Feature flags ---------------------------------------------------------
# Deterministic route for the two hot intents ("do I have X", "who else has X").
# Measured: ~9.8s -> ~5.8s median on those. Falls through to the full agent when
# the drug cannot be resolved unambiguously.
FAST_PATH_ENABLED=true

# KEEP OFF. Whole-question cosine cannot separate "same question" from "different
# strength" — "do I have Panadol" scores HIGHER against "...Panadol 1g" (a
# different product) than against "Do we have Panadol?" (the same question). No
# threshold is safe and a false hit serves the wrong drug's stock. See CLAUDE.md.
SEMANTIC_CACHE_ENABLED=false
SEMANTIC_CACHE_THRESHOLD=0.94

# Adds a second extraction model + 3 history replays to EVERY turn. This is the
# single biggest driver of latency. Off.
LEARNING_ENABLED=false
LEARNING_MODEL=google/gemini-2.5-flash-lite

# Runs the tool loop on a cheap model, phrases with the strong one. Saves cost,
# not latency.
ROUTER_SPLIT_ENABLED=false
ROUTER_MODEL=google/gemini-2.5-flash-lite

# ===== SSO / LDAP (both OFF; see docs/SSO.md before enabling) ==============
# Identity only — the local `users` row decides what a person may DO, and there
# is no self-signup, so a Keycloak realm admin cannot mint a pharmacy admin.
# All of this is also editable at runtime from the admin panel
# (Configuration -> Authentication), which needs no restart.
OIDC_ENABLED=false
OIDC_PROVIDER_NAME=Keycloak
OIDC_DISCOVERY_URL=
OIDC_CLIENT_ID=
# Confidential client. If you make the Keycloak client PUBLIC (no secret), the
# reason this app does not verify id_token signatures collapses — read
# docs/SSO.md before doing that.
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://pharma.yourco.com/auth/sso/callback
OIDC_SCOPES=openid email profile

LDAP_ENABLED=false
LDAP_HOST=
# 636 with LDAP_USE_SSL=true, or 389 with LDAP_START_TLS=true. Never plain 389.
LDAP_PORT=636
LDAP_USE_SSL=true
LDAP_START_TLS=false
# Leave true. False makes the bind MITM-able, i.e. passwords in clear to whoever
# holds the network path.
LDAP_VALIDATE_CERT=true
LDAP_CA_CERT_FILE=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_BASE_DN=
LDAP_USER_FILTER=(uid={username})
LDAP_EMAIL_ATTR=mail
LDAP_NAME_ATTR=cn
