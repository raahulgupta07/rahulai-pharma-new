# --- LLM (OpenRouter) ---
# API key for OpenRouter; get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxxxx
# Model slug routed through OpenRouter
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# --- Postgres ---
# Inventory + catalog store (loaded from the two Excel files)
POSTGRES_URL=postgresql://pharmacy:pharmacy@localhost:5432/pharmacy

# --- Redis ---
# Response / query cache
REDIS_URL=redis://localhost:6379/0
# Cache time-to-live in seconds
CACHE_TTL_SECONDS=600

# --- API limits ---
# Per-client request cap per minute
RATE_LIMIT_PER_MIN=30

# --- Logging ---
LOG_LEVEL=INFO
SECRET_KEY=change-me-32+random-bytes
SESSION_TTL_SECONDS=900
SFTP_PASSWORD=change-me
