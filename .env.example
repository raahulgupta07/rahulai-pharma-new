# =============================================================================
# City Pharma Agent — environment template
#
# Copy to .env and fill in. Every key here maps to a field in app/config.py
# (case-insensitive). Only OPENROUTER_API_KEY is mandatory; the rest have
# working defaults for local dev. For PRODUCTION, deploy/aws/install.sh writes
# .env.prod for you with generated secrets — see .env.prod.example.
# =============================================================================

# --- LLM (OpenRouter ONLY — do not add direct Google/OpenAI/Anthropic SDKs) ---
# API key for OpenRouter; get one at https://openrouter.ai/keys. REQUIRED.
OPENROUTER_API_KEY=sk-or-xxxxx
# Chat model. Selectable per-request in the admin chat UI.
OPENROUTER_MODEL=google/gemini-3.5-flash
# Embedding model (3072-dim), also via OpenRouter.
EMBEDDING_MODEL=google/gemini-embedding-2

# --- Datastores ---
# Inventory + catalog store (loaded from the two Excel/CSV files).
POSTGRES_URL=postgresql://pharmacy:pharmacy@localhost:5432/pharmacy
# Response / query cache + ingest config + embed credentials.
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=600

# --- API limits / logging ---
RATE_LIMIT_PER_MIN=30
LOG_LEVEL=INFO

# --- Secrets / sessions ---
# 32+ random bytes. Must match the Laravel CITYAGENT_SECRET_KEY when embedding
# the widget with HMAC-signed users. It signs sessions AND the embed store_id,
# so a weak/shared value makes store-scoping forgeable.
SECRET_KEY=change-me-32+random-bytes
SESSION_TTL_SECONDS=900
# Legacy /admin gate; superseded by user auth. Leave blank unless you use it.
ADMIN_TOKEN=

# --- Seed super admin (created on FIRST boot only; no public signup) ---
# The break-glass account: works even when Keycloak/LDAP is down.
# NOTE: changing ADMIN_PASSWORD after the account exists does NOT rotate it —
# the seed skips an existing email. Update the users row (or delete + reseed).
ADMIN_EMAIL=admin@citcare.local
ADMIN_PASSWORD=changeme
# How long an issued login token stays valid.
AUTH_TOKEN_TTL_HOURS=12

# --- CORS ---
# Comma-separated origins. Default (in code) is the local dev origins, NOT "*".
# A wildcard lets any site call the embed API from a victim's browser; the app
# logs a warning when "*" is in effect. In production list your real domain(s):
#   ALLOWED_ORIGINS=https://pharma.yourco.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8088,http://localhost:8091
# Set true once served over https (marks the SSO state cookie Secure).
COOKIE_SECURE=false

# --- Data ingest / SFTP watcher ---
# Where a manual reload looks for article*/balance* files.
DATA_DIR=data
# The SFTP drop dir the worker ingests from (the sftp_data volume mounts here).
INCOMING_DIR=data/incoming
# How often the worker scans the drop dir (also settable live in the admin UI).
WATCH_INTERVAL_SECONDS=15
# Embed new/changed catalog rows in the background so an upload returns fast.
EMBED_IN_BACKGROUND=true

# --- SFTP handoff (what a PARTNER connects to) ---
# The shared account partners upload as. SFTP_PASSWORD must match the value
# docker-compose creates the sftp container with.
SFTP_PASSWORD=change-me
SFTP_USERNAME=pharma
# The public host/port a partner dials. Leave HOST blank in dev; the admin page
# auto-detects and asks you to confirm. Set it for a real deploy.
SFTP_PUBLIC_HOST=
SFTP_PUBLIC_PORT=2222
# Where the api container sees the sftp account's .ssh dir (shared sftp_ssh
# volume). Partner-key registration writes here and takes effect with no restart.
SFTP_KEYS_DIR=/sftp_ssh

# --- Embed widget credentials (fail-closed) ---
# The embed API rejects any (embed_id, public_key) that is not registered. To
# keep the documented web/web dev snippet working, ONE credential is seeded on
# startup — only when the store is empty AND this flag is on. It logs a warning.
# PRODUCTION: set EMBED_DEV_CREDENTIAL=false and mint a real credential in the UI.
EMBED_DEV_CREDENTIAL=true
EMBED_DEV_CREDENTIAL_ID=web
EMBED_DEV_CREDENTIAL_KEY=web

# --- Conversation history (multi-turn follow-ups) ---
# ON by default; no extra LLM call, only replayed prompt tokens. Lets "which
# other shop has it?" know what "it" is.
HISTORY_ENABLED=true
HISTORY_TURNS=3
# How long chat logs are kept.
CHAT_LOG_RETENTION_DAYS=30

# =============================================================================
# Keycloak SSO + LDAP  (both OFF by default — see docs/SSO.md before enabling)
#
# Identity only. Keycloak/LDAP prove WHO a person is; the local users row decides
# WHAT they may do. Any source resolves to one row keyed on email. No self-signup:
# an admin must create the user first, or the login is refused.
# =============================================================================

# --- Keycloak / OIDC ---
OIDC_ENABLED=false
OIDC_PROVIDER_NAME=Keycloak
# Realm discovery document. Note "/realms/", not the legacy "/auth/realms/".
OIDC_DISCOVERY_URL=https://keycloak.example.com/realms/citcare/.well-known/openid-configuration
OIDC_CLIENT_ID=pharmacy-agent
# Confidential client. Keycloak 26 defaults Client Authenticator to "None" —
# switch it to "Client ID and secret" or this stays empty and the flow is unsafe.
OIDC_CLIENT_SECRET=
# Must match a Valid Redirect URI in the Keycloak client, exactly.
OIDC_REDIRECT_URI=https://pharmacy.example.com/auth/sso/callback
OIDC_SCOPES=openid email profile
OIDC_DISCOVERY_TTL_SECONDS=300
OIDC_STATE_TTL_SECONDS=600

# --- LDAP / Active Directory ---
LDAP_ENABLED=false
LDAP_HOST=ldap.example.com
# 636 with LDAP_USE_SSL=true, or 389 with LDAP_START_TLS=true. Never plain 389.
LDAP_PORT=636
LDAP_USE_SSL=true
LDAP_START_TLS=false
# Leave true. False disables cert checking and the bind becomes MITM-able.
LDAP_VALIDATE_CERT=true
LDAP_CA_CERT_FILE=
LDAP_TIMEOUT_SECONDS=8
# Service account used to SEARCH for the user. Needs read, nothing more.
LDAP_BIND_DN=cn=svc-pharmacy,ou=service,dc=corp,dc=com
LDAP_BIND_PASSWORD=
LDAP_BASE_DN=ou=users,dc=corp,dc=com
# {username} is substituted and escaped. AD is usually (sAMAccountName={username}).
LDAP_USER_FILTER=(uid={username})
LDAP_EMAIL_ATTR=mail
LDAP_NAME_ATTR=cn

# --- Feature flags (all default OFF unless noted; see README) ---
# Long-term memory. Adds a second model call to EVERY turn. Preferences only.
LEARNING_ENABLED=false
LEARNING_MODEL=google/gemini-2.5-flash-lite
# Deterministic route for the two hot intents: zero-LLM resolve + 1 SQL + 1
# phrasing call. Falls through to the agent when ambiguous.
FAST_PATH_ENABLED=false
# KEEP OFF — whole-question cosine cannot separate "same question" from
# "different strength". See config.py / README.
SEMANTIC_CACHE_ENABLED=false
SEMANTIC_CACHE_THRESHOLD=0.94
# Run the tool loop on a cheap model, phrase with the strong one. Saves cost,
# not latency.
ROUTER_SPLIT_ENABLED=false
ROUTER_MODEL=google/gemini-2.5-flash-lite

# =============================================================================
# MySQL source sync (optional) — pull the client's app DB into our Postgres.
# We NEVER write to their DB: a read-only account runs two SELECTs whose column
# ALIASES map their schema onto ours. Override the SQL to match their tables.
# =============================================================================
MYSQL_SYNC_ENABLED=false
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DB=
# MYSQL_CATALOG_SQL=SELECT code AS article_code, name AS brand_name, ... FROM products
# MYSQL_INVENTORY_SQL=SELECT product_code AS article_code, branch_code AS site_code, ... FROM stock
